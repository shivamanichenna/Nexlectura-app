rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isStudent() {
      return isSignedIn() && getUserRole() == 'student';
    }

    function isLecturer() {
      return isSignedIn() && getUserRole() == 'lecturer';
    }

    // ─── Users ──────────────────────────────────────────────────────────────
    // Users can read/write only their own profile

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasAll(['uid', 'email', 'name', 'role'])
        && request.resource.data.role in ['student', 'lecturer'];
      allow update: if isOwner(uid)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['uid', 'role']);
    }

    // ─── Students ────────────────────────────────────────────────────────────
    // Students can read/write their own profile

    match /students/{uid} {
      allow read: if isOwner(uid) || isLecturer();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
    }

    // ─── Lecturers ───────────────────────────────────────────────────────────
    // Lecturers can read/write their own profile
    // Students can read lecturer profiles (for display)

    match /lecturers/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
    }

    // ─── Lectures ─────────────────────────────────────────────────────────────
    // Any signed-in user can read lectures
    // Only lecturers can create/update/delete their own lectures

    match /lectures/{lectureId} {
      allow read: if isSignedIn();
      allow create: if isLecturer()
        && request.resource.data.lecturerId == request.auth.uid;
      allow update: if isLecturer()
        && resource.data.lecturerId == request.auth.uid;
      allow delete: if isLecturer()
        && resource.data.lecturerId == request.auth.uid;
    }

    // ─── Chats (Doubt Messages) ────────────────────────────────────────────────
    // Users can only access their own chat history

    match /chats/{uid}/messages/{messageId} {
      allow read, write: if isOwner(uid);
    }

    // ─── Flashcards ────────────────────────────────────────────────────────────
    // Users can only access their own flashcard sets

    match /flashcards/{uid}/sets/{setId} {
      allow read, write: if isOwner(uid);
    }

    // ─── Quizzes ───────────────────────────────────────────────────────────────
    // Users can only access their own quizzes and attempts

    match /quizzes/{uid}/generated/{quizId} {
      allow read, write: if isOwner(uid);
    }

    match /quizzes/{uid}/attempts/{attemptId} {
      allow read, write: if isOwner(uid);
    }

    // ─── Progress ──────────────────────────────────────────────────────────────
    // Students read/write their own progress
    // Lecturers can read student progress for their section (analytics)

    match /progress/{uid} {
      allow read: if isOwner(uid) || isLecturer();
      allow write: if isOwner(uid);
    }

    // ─── Notifications ─────────────────────────────────────────────────────────
    // Users only see their own notifications
    // Lecturers can create notifications for students

    match /notifications/{uid}/items/{notifId} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid) || isLecturer();
    }

    // ─── Deny everything else ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
